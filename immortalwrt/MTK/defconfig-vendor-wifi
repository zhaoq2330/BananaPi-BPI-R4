# ImmortalWrt openwrt-25.12 minimal defconfig for BPI-R4 vendor WiFi test.
# Purpose: verify MTK vendor mt76-vendor driver compiles and boots.
# This is a stripped-down config: no Docker, no proxy, no extras.

CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_bananapi_bpi-r4=y
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_TOOLCHAINOPTS=y
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set
CONFIG_TARGET_ROOTFS_PARTSIZE=1024
CONFIG_IPV6=y
CONFIG_DRIVER_11BE_SUPPORT=y

# Minimal networking.
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# MTK vendor WiFi stack: replaces kmod-mt76* / kmod-mt799*.
CONFIG_PACKAGE_kmod-cfg80211=y
# CONFIG_PACKAGE_kmod-mac80211 is not set
CONFIG_PACKAGE_mt76-vendor=y
CONFIG_PACKAGE_kmod-mtk_wed=y
CONFIG_PACKAGE_kmod-mediatek_hnat=y

# MTK platform packages (minimum set).
# overlayfs_encryption depends on dmsetup which does not exist — disable.
# CONFIG_PACKAGE_overlayfs_encryption is not set
CONFIG_PACKAGE_mii_mgr=y
CONFIG_PACKAGE_regs=y
CONFIG_PACKAGE_switch=y

# NPU.
CONFIG_PACKAGE_kmod-npu=y
CONFIG_PACKAGE_npu-rebb-fw=y
CONFIG_PACKAGE_kmod-npu-flow=y
CONFIG_PACKAGE_kmod-npu-flow-autoload=y
CONFIG_PACKAGE_kmod-npu-nf_hnat=y
CONFIG_PACKAGE_kmod-npu-nf_hnat-autoload=y
CONFIG_PACKAGE_kmod-npu-mcast=y
CONFIG_PACKAGE_kmod-npu-mcast-autoload=y

# MTK debug tools.
CONFIG_PACKAGE_pce=y
CONFIG_PACKAGE_mtkhnat_util=y
CONFIG_PACKAGE_ethswbox=y
CONFIG_PACKAGE_flowtable=y
CONFIG_PACKAGE_tops-tool=y

# Basic userspace.
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ethtool-full=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_wget-ssl=y

# LuCI minimal.
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# SFP / PHY.
CONFIG_PACKAGE_kmod-sfp=y
CONFIG_PACKAGE_kmod-phy-aquantia=y
CONFIG_PACKAGE_aqr10g-phy-fw=y
CONFIG_PACKAGE_kmod-phy-marvell-10g=y
CONFIG_PACKAGE_kmod-phy-realtek=y
