+function getWifiBandFromFrequency(freq) {
+	const mhz = freq?.mhz;
+
+	if (mhz >= 57000)
+		return '60g';
+	if (mhz >= 5925)
+		return '6g';
+	if (mhz >= 5000)
+		return '5g';
+	if (mhz >= 2400)
+		return '2g';
+
+	switch (freq?.band) {
+	case 1:
+	case 2:
+		return '2g';
+
+	case 3:
+	case 6:
+		return '6g';
+
+	case 4:
+	case 60:
+		return '60g';
+
+	case 5:
+		return '5g';
+
+	default:
+		return null;
+	}
+}
+
+function getFallbackWifiHwModes(band, allow2gAc) {
+	const modes = {};
+
+	switch (band) {
+	case '2g':
+		modes.b = true;
+		modes.g = true;
+		modes.n = true;
+		modes.ax = true;
+		modes.be = true;
+		if (allow2gAc)
+			modes.ac = true;
+		break;
+
+	case '5g':
+		modes.a = true;
+		modes.n = true;
+		modes.ac = true;
+		modes.ax = true;
+		modes.be = true;
+		break;
+
+	case '6g':
+		modes.ax = true;
+		modes.be = true;
+		break;
+	}
+
+	return modes;
+}
+
+function getFallbackWifiHtModes(band, allow2gAc) {
+	const modes = {};
+	const add = (...entries) => entries.forEach(entry => modes[entry] = true);
+
+	switch (band) {
+	case '2g':
+		add('HT20', 'HT40', 'HE20', 'HE40', 'EHT20', 'EHT40');
+		if (allow2gAc)
+			add('VHT20', 'VHT40');
+		break;
+
+	case '5g':
+		add(
+			'HT20', 'HT40',
+			'VHT20', 'VHT40', 'VHT80', 'VHT80_80', 'VHT160',
+			'HE20', 'HE40', 'HE80', 'HE80_80', 'HE160',
+			'EHT20', 'EHT40', 'EHT80', 'EHT80_80', 'EHT160'
+		);
+		break;
+
+	case '6g':
+		add(
+			'HE20', 'HE40', 'HE80', 'HE80_80', 'HE160',
+			'EHT20', 'EHT40', 'EHT80', 'EHT80_80', 'EHT160', 'EHT320'
+		);
+		break;
+	}
+
+	return modes;
+}
